{
  "name": "falcosend-sdk",
  "version": "1.0.0",
  "description": "A high-performance Node.js and TypeScript SDK for seamlessly integrating and sending notifications via the FalcoSend API.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm,iife --dts --minify --clean --globalName FalcoSend",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "Falcosend",
    "Form Submission"
  ],
  "author": "Elkana Maina <elisoft.engineer@gmail.com> (https://elkana.ellypad.com)",
  "license": "ISC",
  "packageManager": "pnpm@10.30.0",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
